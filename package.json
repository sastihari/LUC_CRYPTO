{
  "name": "lucifer-token",
  "version": "1.0.0",
  "description": "LUCIFER (LUC) Token - Built with Multi-Agent AI System",
  "main": "index.js",
  "scripts": {
    "test":            "hardhat test",
    "compile":         "hardhat compile",
    "deploy:both":     "node scripts/deployBoth.js",
    "deploy:sepolia":  "hardhat run scripts/deploy.js --network sepolia",
    "deploy:amoy":     "hardhat run scripts/deploy.js --network amoy",
    "deploy:polygon":  "hardhat run scripts/deploy.js --network polygon",
    "verify:sepolia":  "hardhat verify --network sepolia",
    "verify:amoy":     "hardhat verify --network amoy",
    "verify:polygon":  "hardhat verify --network polygon",
    "balance":         "node scripts/walletAgent.js",
    "balance:watch":   "node scripts/walletAgent.js --watch",
    "node":            "hardhat node",
    "console":         "hardhat console"
  },
  "keywords": [
    "ethereum",
    "polygon",
    "erc20",
    "token",
    "cryptocurrency",
    "multi-agent",
    "ai"
  ],
  "author": "LUCIFER Project Team",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.9",
    "ws": "^8.19.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.1",
    "dotenv": "^16.3.1"
  }
}
