# LUC Token Deployment Configuration
# ⚠️ Copy this to .env.hardhat and add your real values

# Wallet Configuration (from generateWallet.js)
PRIVATE_KEY=33f4d9151f7f63f975af152dc154e99a2618ae08cbabc7a5c2940d5349efb160
DEPLOYER_ADDRESS=your_wallet_address

# Network Configuration - AMOY (New Polygon Testnet - replacing Mumbai)
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Polygon Mainnet
POLYGON_RPC_URL=https://polygon-rpc.com

# Legacy Mumbai (DEPRECATED - use Amoy)
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com

# PolygonScan API (get from https://polygonscan.com/apis)
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Gas Settings
REPORT_GAS=true

# ⚠️ IMPORTANT:
# - Mumbai testnet is DEPRECATED
# - Use AMOY testnet instead (Chain ID: 80002)
# - Amoy faucets may require mainnet ETH balance
